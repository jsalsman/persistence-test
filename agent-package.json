{
    "name": "@guildai/jsalsman~repo-change-summarizer",
    "version": "5.0.2",
    "author": "Guild.ai",
    "type": "module",
    "exports": {
        ".": "./dist/agent.compiled.js"
    },
    "scripts": {
        "build": "tsc --build && babel ./dist/agent.js --out-dir ./dist --out-file-extension .compiled.js --plugins @guildai/babel-plugin-agent-compiler",
        "clean": "tsc --build --clean && rm -rf dist node_modules",
        "lint": "eslint src",
        "format": "prettier --write src",
        "format:check": "prettier --check src"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.3",
        "@guildai/babel-plugin-agent-compiler": "*",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "@guildai/agents-sdk": "*",
        "zod": "^4.3.0",
        "@guildai-services/guildai~github": "*"
    },
    "files": [
        "./dist/**/*.js",
        "./dist/**/*.d.ts"
    ]
}
